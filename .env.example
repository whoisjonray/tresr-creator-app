# Server Configuration
NODE_ENV=production
PORT=3000

# Dynamic Mockups API Configuration
DYNAMIC_MOCKUPS_ENABLED=false
DYNAMIC_MOCKUPS_API_KEY=your_dynamic_mockups_api_key
DYNAMIC_MOCKUPS_WEBSITE_KEY=your_dynamic_mockups_website_key

# Feature Flags for Dynamic Mockups
REACT_APP_USE_DYNAMIC_MOCKUPS=false
REACT_APP_DM_MODE=disabled
REACT_APP_ENABLE_EXPERIMENTAL_ROUTES=true
REACT_APP_ENABLE_COMPARISON_DASHBOARD=true
REACT_APP_BETA_CREATORS=
REACT_APP_TRACK_MOCKUP_PERFORMANCE=true
REACT_APP_ENABLE_DM_CACHE=true
REACT_APP_DM_CACHE_TTL=86400
REACT_APP_ENABLE_BULK_RENDER=true
REACT_APP_ENABLE_PRINT_FILES=true
REACT_APP_FALLBACK_TO_CANVAS=true
REACT_APP_AB_TEST_ENABLED=false
REACT_APP_AB_TEST_PERCENTAGE=10

# Shopify Configuration
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_STORE_DOMAIN=becc05-b4.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token

# Dynamic.xyz Configuration
DYNAMIC_ENV_ID=b17e8631-c1b7-45d5-95cf-151eb5246423
DYNAMIC_AUTH_URL=https://auth.tresr.com

# Backend URLs
SHOPIFY_APP_URL=https://vibes.tresr.com

# Database Configuration (Optional for Railway)
DATABASE_URL=mysql://user:password@host:3306/database
REDIS_URL=redis://user:password@host:6379

# Session Configuration
SESSION_SECRET=your_session_secret_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Cloudinary Configuration (Required for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Sanity Configuration (Required for importing designs from Sanity)
SANITY_PROJECT_ID=a9vtdosx
SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token