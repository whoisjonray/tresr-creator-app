# Dynamic Mockups API Configuration
DYNAMIC_MOCKUPS_ENABLED=true
DYNAMIC_MOCKUPS_API_KEY=your-api-key-here
DYNAMIC_MOCKUPS_WEBSITE_KEY=

# React App Feature Flags
REACT_APP_USE_DYNAMIC_MOCKUPS=true
REACT_APP_DM_MODE=api
REACT_APP_ENABLE_EXPERIMENTAL_ROUTES=true
REACT_APP_ENABLE_COMPARISON_DASHBOARD=true
REACT_APP_TRACK_MOCKUP_PERFORMANCE=true
REACT_APP_ENABLE_DM_CACHE=true
REACT_APP_DM_CACHE_TTL=86400
REACT_APP_ENABLE_BULK_RENDER=true
REACT_APP_ENABLE_PRINT_FILES=true
REACT_APP_FALLBACK_TO_CANVAS=true

# Shopify Configuration
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_STORE_DOMAIN=becc05-b4.myshopify.com

# Dynamic.xyz Authentication
DYNAMIC_ENV_ID=
DYNAMIC_AUTH_URL=https://auth.tresr.com

# Session Management
SESSION_SECRET=
JWT_SECRET=

# Database (Railway provides automatically)
DATABASE_URL=
REDIS_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS (for S3/Cloudinary)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
