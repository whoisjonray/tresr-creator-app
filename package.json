{
  "name": "tresr-creator-app",
  "version": "2.0.0",
  "description": "TRESR Creator Tools - Design editor and product management for creators",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build": "npm run install:all && npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "start": "cd server && npm start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest tests/integration.test.js"
  },
  "keywords": [
    "shopify",
    "creator-tools",
    "design-editor",
    "product-management"
  ],
  "author": "TRESR",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "concurrently": "^8.2.2",
    "jest": "^30.0.5",
    "nock": "^14.0.10",
    "supertest": "^7.1.4"
  },
  "dependencies": {
    "@sanity/client": "^7.8.2",
    "cloudinary": "^2.7.0",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "node-fetch": "^3.3.2"
  }
}
